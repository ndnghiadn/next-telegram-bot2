# Copy file này thành .env.local và điền vào

# Lấy từ @BotFather trên Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# URL production của bạn trên Vercel (không có dấu / ở cuối)
# VD: https://my-bot.vercel.app
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Secret để verify webhook request thật sự từ Telegram
# Tự đặt 1 chuỗi random, VD: openssl rand -hex 32
WEBHOOK_SECRET=your_random_secret_here

# Admin password để vào trang /admin
ADMIN_PASSWORD=changeme123

# (Tùy chọn) Chat ID của admin để nhận thông báo lỗi
ADMIN_CHAT_ID=
